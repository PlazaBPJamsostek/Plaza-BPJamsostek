    <style>
        * {
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: #0a0e27;
            color: #e0e0e0;
            overflow-x: hidden;
        }

        /* Hero Section Styles */
        .hero-section {
            position: relative;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 50%, #0f1428 100%);
            overflow: hidden;
        }

        .hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(ellipse at center, rgba(10, 14, 39, 0) 0%, rgba(10, 14, 39, 0.9) 100%);
            z-index: 1;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            animation: fadeInUp 1.5s ease-out;
        }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: 4.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #d4af37 0%, #c9a961 50%, #b8860b 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 30px rgba(212, 175, 55, 0.3);
            letter-spacing: 2px;
        }

        .hero-subtitle {
            font-size: 1.5rem;
            color: #a0aec0;
            margin-bottom: 2rem;
            font-weight: 300;
            letter-spacing: 1px;
        }

        /* Glassmorphism Button */
        .btn-glass {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 0.875rem 2rem;
            border-radius: 0.5rem;
            color: #d4af37;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-block;
            margin: 0.5rem;
            text-decoration: none;
        }

        .btn-glass:hover {
            background: rgba(212, 175, 55, 0.1);
            border-color: #d4af37;
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.5);
            transform: translateY(-3px);
        }

        .btn-primary {
            background: linear-gradient(135deg, #d4af37 0%, #b8860b 100%);
            color: #0a0e27;
            border: none;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(212, 175, 55, 0.4);
        }

        /* Navbar Styles */
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            transition: all 0.3s ease;
            background: rgba(10, 14, 39, 0);
            backdrop-filter: blur(0px);
        }

        .navbar.scrolled {
            background: rgba(10, 14, 39, 0.95);
            backdrop-filter: blur(10px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .navbar-container {
            max-width: 7xl;
            margin: 0 auto;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar-logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, #d4af37 0%, #c9a961 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            cursor: pointer;
        }

        .navbar-menu {
            display: flex;
            gap: 2rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .navbar-menu a {
            color: #a0aec0;
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
        }

        .navbar-menu a:hover {
            color: #d4af37;
        }

        .navbar-menu a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: #d4af37;
            transition: width 0.3s ease;
        }

        .navbar-menu a:hover::after {
            width: 100%;
        }

        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            color: #d4af37;
            font-size: 1.5rem;
            cursor: pointer;
        }

        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes glow {
            0%, 100% {
                box-shadow: 0 0 5px rgba(212, 175, 55, 0.5);
            }
            50% {
                box-shadow: 0 0 20px rgba(212, 175, 55, 0.8);
            }
        }

        @keyframes float {
            0%, 100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-10px);
            }
        }

        /* Floor Card Styles */
        .floor-card {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.3);
            padding: 2rem;
            border-radius: 1rem;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            min-height: 250px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .floor-card:hover {
            background: rgba(212, 175, 55, 0.1);
            border-color: #d4af37;
            transform: translateY(-10px);
            box-shadow: 0 10px 40px rgba(212, 175, 55, 0.3);
        }

        .floor-icon {
            font-size: 3rem;
            color: #d4af37;
            margin-bottom: 1rem;
            transition: all 0.3s ease;
        }

        .floor-card:hover .floor-icon {
            transform: scale(1.2) rotate(5deg);
            animation: glow 0.6s ease-in-out;
        }

        .floor-name {
            font-size: 1.25rem;
            font-weight: 600;
            color: #d4af37;
            margin-bottom: 0.5rem;
        }

        .floor-description {
            font-size: 0.9rem;
            color: #a0aec0;
        }

        /* Facility Card */
        .facility-card {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.2);
            padding: 2rem;
            border-radius: 1rem;
            text-align: center;
            transition: all 0.3s ease;
        }

        .facility-card:hover {
            background: rgba(212, 175, 55, 0.1);
            border-color: #d4af37;
            transform: translateY(-10px);
            box-shadow: 0 10px 40px rgba(212, 175, 55, 0.3);
        }

        .facility-icon {
            font-size: 2.5rem;
            color: #d4af37;
            margin-bottom: 1rem;
        }

        .facility-name {
            font-size: 1.1rem;
            font-weight: 600;
            color: #e0e0e0;
        }

        /* Section Styles */
        .section {
            padding: 5rem 2rem;
            max-width: 7xl;
            margin: 0 auto;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 1rem;
            text-align: center;
            background: linear-gradient(135deg, #d4af37 0%, #c9a961 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .section-subtitle {
            text-align: center;
            color: #a0aec0;
            font-size: 1.1rem;
            margin-bottom: 3rem;
        }

        .divider {
            width: 60px;
            height: 3px;
            background: linear-gradient(135deg, #d4af37 0%, #b8860b 100%);
            margin: 0 auto 2rem;
        }

        /* Gallery Styles */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }

        .gallery-item {
            position: relative;
            overflow: hidden;
            border-radius: 1rem;
            cursor: pointer;
            height: 300px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.2);
        }

        .gallery-item-bg {
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #1a1f3a 0%, #2d2e4a 100%);
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #d4af37;
            font-size: 3rem;
        }

        .gallery-item:hover .gallery-item-bg {
            transform: scale(1.1);
        }

        .gallery-item-label {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(10, 14, 39, 0.9), transparent);
            padding: 1.5rem;
            color: #d4af37;
            font-weight: 600;
        }

        /* Pricing Card */
        .pricing-card {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid rgba(212, 175, 55, 0.3);
            padding: 2rem;
            border-radius: 1rem;
            transition: all 0.3s ease;
        }

        .pricing-card.featured {
            border-color: #d4af37;
            background: rgba(212, 175, 55, 0.1);
            transform: scale(1.05);
        }

        .pricing-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 40px rgba(212, 175, 55, 0.3);
        }

        .pricing-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #d4af37;
            margin-bottom: 1rem;
        }

        .pricing-description {
            color: #a0aec0;
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
        }

        /* Contact Form */
        .contact-form input,
        .contact-form textarea {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.3);
            color: #e0e0e0;
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
            width: 100%;
            font-family: 'Poppins', sans-serif;
            transition: all 0.3s ease;
        }

        .contact-form input:focus,
        .contact-form textarea:focus {
            outline: none;
            background: rgba(255, 255, 255, 0.1);
            border-color: #d4af37;
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.3);
        }

        /* Footer */
        footer {
            background: rgba(10, 14, 39, 0.8);
            border-top: 1px solid rgba(212, 175, 55, 0.2);
            padding: 3rem 2rem;
        }

        .footer-content {
            max-width: 7xl;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .footer-section h4 {
            color: #d4af37;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .footer-section ul {
            list-style: none;
            padding: 0;
        }

        .footer-section ul li a {
            color: #a0aec0;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .footer-section ul li a:hover {
            color: #d4af37;
        }

        .social-icons {
            display: flex;
            gap: 1rem;
            margin-top: 1rem;
        }

        .social-icon {
            width: 40px;
            height: 40px;
            border: 1px solid rgba(212, 175, 55, 0.3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #d4af37;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .social-icon:hover {
            background: rgba(212, 175, 55, 0.1);
            transform: translateY(-3px);
        }

        .footer-bottom {
            text-align: center;
            padding-top: 2rem;
            border-top: 1px solid rgba(212, 175, 55, 0.2);
            color: #718096;
        }

        /* Scroll to Top Button */
        .scroll-to-top {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #d4af37 0%, #b8860b 100%);
            border: none;
            border-radius: 50%;
            color: #0a0e27;
            font-size: 1.5rem;
            cursor: pointer;
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 999;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(212, 175, 55, 0.4);
        }

        .scroll-to-top.show {
            display: flex;
        }

        .scroll-to-top:hover {
            transform: scale(1.1);
        }

        /* WhatsApp Button */
        .whatsapp-btn {
            position: fixed;
            bottom: 2rem;
            right: 7rem;
            width: 60px;
            height: 60px;
            background: #25D366;
            border: none;
            border-radius: 50%;
            color: white;
            font-size: 1.8rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 999;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(37, 211, 102, 0.4);
            animation: float 3s ease-in-out infinite;
        }

        .whatsapp-btn:hover {
            transform: scale(1.15);
            box-shadow: 0 10px 30px rgba(37, 211, 102, 0.6);
        }

        /* Loading Screen */
        .loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #0a0e27;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            animation: fadeOut 0.5s ease-out 2s forwards;
        }

        .loading-content {
            text-align: center;
        }

        .loading-logo {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #d4af37 0%, #c9a961 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 2rem;
        }

        .loading-spinner {
            border: 4px solid rgba(212, 175, 55, 0.3);
            border-top: 4px solid #d4af37;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        @keyframes fadeOut {
            to {
                opacity: 0;
                visibility: hidden;
            }
        }

        /* Counter Animation */
        .counter {
            font-size: 2.5rem;
            font-weight: 700;
            color: #d4af37;
        }

        .counter-label {
            color: #a0aec0;
            font-size: 0.95rem;
            margin-top: 0.5rem;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .hero-title {
                font-size: 2.5rem;
            }

            .navbar-menu {
                display: none;
            }

            .mobile-menu-btn {
                display: block;
            }

            .pricing-card.featured {
                transform: scale(1);
            }

            .whatsapp-btn {
                right: 1rem;
            }

            .scroll-to-top {
                right: 1rem;
            }
        }
    </style>
</head>
<body>
    <!-- Loading Screen -->
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-logo">PLAZA BPJAMSOSTEK</div>
            <div class="loading-spinner"></div>
        </div>
    </div>

    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="navbar-container">
            <div class="navbar-logo">PLAZA BPJamsostek</div>
            <ul class="navbar-menu">
                <li><a href="#home">Home</a></li>
                <li><a href="#directory">Directory</a></li>
                <li><a href="#facilities">Facilities</a></li>
                <li><a href="#rental">Rental</a></li>
                <li><a href="#gallery">Gallery</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
            <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero-section">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <h1 class="hero-title" data-aos="fade-up" data-aos-delay="0">PLAZA BPJAMSOSTEK</h1>
            <p class="hero-subtitle" data-aos="fade-up" data-aos-delay="100">Premium Office Tower in Jakarta</p>
            <div data-aos="fade-up" data-aos-delay="200">
                <button class="btn-glass" onclick="scrollToSection('directory')">
                    <i class="fas fa-building"></i> Explore Building
                </button>
                <button class="btn-primary" onclick="scrollToSection('rental')">
                    <i class="fas fa-phone"></i> Rental Information
                </button>
            </div>
        </div>
    </section>

    <!-- Building Directory Section -->
    <section id="directory" class="section bg-gradient-to-b from-transparent via-blue-950/10 to-transparent">
        <h2 class="section-title" data-aos="fade-up">Building Directory</h2>
        <div class="divider" data-aos="fade-up"></div>
        <p class="section-subtitle" data-aos="fade-up">Explore our premium floors and facilities</p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-8">
            <div class="floor-card" data-aos="fade-up" data-aos-delay="50">
                <div class="floor-icon"><i class="fas fa-users"></i></div>
                <div class="floor-name">Lantai 19–30</div>
                <div class="floor-description">Kantor Pusat BPJS Ketenagakerjaan</div>
            </div>

            <div class="floor-card" data-aos="fade-up" data-aos-delay="100">
                <div class="floor-icon"><i class="fas fa-briefcase"></i></div>
                <div class="floor-name">Lantai 18 & 12</div>
                <div class="floor-description">Office Space Available For Rent</div>
            </div>

            <div class="floor-card" data-aos="fade-up" data-aos-delay="150">
                <div class="floor-icon"><i class="fas fa-utensils"></i></div>
                <div class="floor-name">Lantai 8</div>
                <div class="floor-description">Foodcourt Area</div>
            </div>

            <div class="floor-card" data-aos="fade-up" data-aos-delay="200">
                <div class="floor-icon"><i class="fas fa-champagne-glasses"></i></div>
                <div class="floor-name">Lantai 6</div>
                <div class="floor-description">Ballroom & Meeting Room Rental</div>
            </div>

            <div class="floor-card" data-aos="fade-up" data-aos-delay="250">
                <div class="floor-icon"><i class="fas fa-mosque"></i></div>
                <div class="floor-name">Lantai R</div>
                <div class="floor-description">Mosque & Badminton Court</div>
            </div>

            <div class="floor-card" data-aos="fade-up" data-aos-delay="300">
                <div class="floor-icon"><i class="fas fa-door-open"></i></div>
                <div class="floor-name">Ground Floor</div>
                <div class="floor-description">Main Lobby & Banking Services</div>
            </div>

            <div class="floor-card" data-aos="fade-up" data-aos-delay="350">
                <div class="floor-icon"><i class="fas fa-truck"></i></div>
                <div class="floor-name">B1</div>
                <div class="floor-description">Loading Dock & Car Parking</div>
            </div>

            <div class="floor-card" data-aos="fade-up" data-aos-delay="400">
                <div class="floor-icon"><i class="fas fa-car"></i></div>
                <div class="floor-name">B2</div>
                <div class="floor-description">Canteen & Car Parking</div>
            </div>

            <div class="floor-card" data-aos="fade-up" data-aos-delay="450">
                <div class="floor-icon"><i class="fas fa-motorcycle"></i></div>
                <div class="floor-name">B3</div>
                <div class="floor-description">Motorcycle Parking Area</div>
            </div>

            <div class="floor-card" data-aos="fade-up" data-aos-delay="500">
                <div class="floor-icon"><i class="fas fa-square"></i></div>
                <div class="floor-name">P3–P5</div>
                <div class="floor-description">Premium Car Parking Area</div>
            </div>
        </div>
    </section>

    <!-- Statistics Section -->
    <section class="section bg-gradient-to-r from-blue-950/20 via-purple-950/20 to-blue-950/20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
            <div data-aos="fade-up">
                <div class="counter" id="counter1">0</div>
                <div class="counter-label">Total Floors</div>
            </div>
            <div data-aos="fade-up" data-aos-delay="100">
                <div class="counter" id="counter2">0</div>
                <div class="counter-label">Premium Facilities</div>
            </div>
            <div data-aos="fade-up" data-aos-delay="200">
                <div class="counter" id="counter3">0</div>
                <div class="counter-label">24/7 Security</div>
            </div>
        </div>
    </section>

    <!-- Facilities Section -->
    <section id="facilities" class="section">
        <h2 class="section-title" data-aos="fade-up">World-Class Facilities</h2>
        <div class="divider" data-aos="fade-up"></div>
