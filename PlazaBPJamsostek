<!DOCTYPE html>
<html lang="id" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ballroom Plaza BPJamsostek — Wedding & Seminar Premium Jakarta</title>
<meta name="description" content="Ballroom mewah Grade A di Kuningan Jakarta. Kapasitas 1.000+ tamu. Venue premium untuk wedding, seminar, dan gala dinner bergengsi.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Didact+Gothic&family=Cinzel:wght@400;600;700&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════
   ROOT TOKENS
═══════════════════════════════════════════════ */
:root {
  --ob:    #07080F;   /* obsidian base */
  --ob2:   #0D0E1A;   /* obsidian mid */
  --ob3:   #13152A;   /* obsidian light */
  --gold:  #C9A84C;   /* classic gold */
  --goldb: #E8C96A;   /* bright gold */
  --goldd: #8A6820;   /* dark gold */
  --ivory: #F5EDD8;   /* warm ivory */
  --ivoryD:#D6C9A8;   /* dim ivory */
  --white: #FFFFFF;
  --txt:   rgba(245,237,216,.85);
  --txtD:  rgba(245,237,216,.45);
  --border: rgba(201,168,76,.15);
  --r-s: 8px; --r-m: 14px; --r-l: 22px; --r-xl: 32px;
}
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; scroll-padding-top:80px; }
body {
  font-family:'Didact Gothic', system-ui, sans-serif;
  background:var(--ob); color:var(--txt);
  overflow-x:hidden; -webkit-font-smoothing:antialiased;
}
img { display:block; max-width:100%; }
a { text-decoration:none; color:inherit; }
button { font-family:inherit; cursor:pointer; border:none; background:none; }

/* ═══════════════════════
   TYPEFACES
═══════════════════════ */
.serif { font-family:'Libre Baskerville', Georgia, serif; }
.cinzel { font-family:'Cinzel', serif; }

/* ═══════════════════════
   UTILITIES
═══════════════════════ */
.container { max-width:1240px; margin:0 auto; padding:0 40px; }
[data-reveal] { opacity:0; transform:translateY(40px); transition:opacity .9s cubic-bezier(.25,.46,.45,.94), transform .9s cubic-bezier(.25,.46,.45,.94); }
[data-reveal="left"]  { transform:translateX(-40px); }
[data-reveal="right"] { transform:translateX(40px); }
[data-reveal="scale"] { transform:scale(.93); }
[data-reveal].vis { opacity:1; transform:none !important; }
[data-d="1"] { transition-delay:.12s; }
[data-d="2"] { transition-delay:.24s; }
[data-d="3"] { transition-delay:.36s; }
[data-d="4"] { transition-delay:.48s; }
[data-d="5"] { transition-delay:.60s; }

/* ═══════════════════════
   GOLD LINE
═══════════════════════ */
.gold-rule { display:flex; align-items:center; gap:14px; margin:18px 0 28px; }
.gold-rule .line { width:48px; height:1px; background:linear-gradient(90deg,var(--gold),transparent); }
.gold-rule .gem  { width:5px; height:5px; background:var(--gold); transform:rotate(45deg); flex-shrink:0; }
.sec-tag {
  font-family:'Cinzel', serif; font-size:10px; letter-spacing:.22em;
  text-transform:uppercase; color:var(--gold); display:flex; align-items:center; gap:10px;
  margin-bottom:10px;
}
.sec-tag::before { content:''; width:28px; height:1px; background:var(--gold); flex-shrink:0; }
.sec-h { font-family:'Libre Baskerville', serif; font-size:clamp(34px,4.5vw,60px); font-weight:700; line-height:1.08; letter-spacing:-.02em; color:var(--white); }
.sec-h em { font-style:italic; color:var(--goldb); }
.sec-p { font-size:16px; color:var(--txtD); line-height:1.9; margin-top:14px; font-weight:400; max-width:540px; }

/* ═══════════════════════════════════════
   NAVBAR
═══════════════════════════════════════ */
#nav {
  position:fixed; top:0; left:0; right:0; z-index:500;
  transition:background .4s, border-color .4s, box-shadow .4s;
}
#nav.solid {
  background:rgba(7,8,15,.96); backdrop-filter:blur(24px);
  border-bottom:1px solid var(--border);
  box-shadow:0 2px 40px rgba(0,0,0,.4);
}
.nav-in {
  max-width:1240px; margin:0 auto; padding:0 40px;
  height:72px; display:flex; align-items:center;
}
.nav-logo { display:flex; align-items:center; gap:13px; margin-right:auto; }
.nav-gem {
  width:44px; height:44px; position:relative;
  display:flex; align-items:center; justify-content:center;
}
.nav-gem::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg,var(--goldb),var(--goldd));
  clip-path:polygon(50% 0,100% 50%,50% 100%,0 50%);
  box-shadow:0 0 18px rgba(201,168,76,.4);
}
.nav-gem span { position:relative; z-index:1; font-size:18px; }
.nav-logo-text { line-height:1.25; }
.nav-logo-text strong { font-family:'Cinzel',serif; font-size:14px; font-weight:600; color:white; display:block; letter-spacing:.06em; }
.nav-logo-text small { font-size:10px; color:rgba(255,255,255,.3); letter-spacing:.12em; }
.nav-links { display:flex; gap:0; margin:0 20px; }
.nav-links a {
  font-family:'Cinzel',serif; font-size:11px; letter-spacing:.1em;
  color:rgba(255,255,255,.5); padding:8px 14px; border-radius:6px;
  transition:color .2s, background .2s; text-transform:uppercase;
}
.nav-links a:hover { color:var(--goldb); background:rgba(201,168,76,.07); }
.nav-actions { display:flex; align-items:center; gap:10px; }

/* Language picker */
.lang-wrap { position:relative; }
.lang-pill {
  display:flex; align-items:center; gap:7px;
  background:rgba(201,168,76,.08); border:1px solid rgba(201,168,76,.2);
  color:var(--goldb); font-family:'Cinzel',serif; font-size:11px; letter-spacing:.1em;
  padding:8px 14px; border-radius:9px; cursor:pointer;
  transition:all .2s;
}
.lang-pill:hover { background:rgba(201,168,76,.15); border-color:var(--gold); }
.lang-pill .globe { width:13px; height:13px; }
.lang-dd {
  position:absolute; top:calc(100%+10px); right:0;
  background:rgba(10,11,22,.98); border:1px solid rgba(201,168,76,.18);
  border-radius:14px; padding:7px; min-width:200px;
  box-shadow:0 24px 60px rgba(0,0,0,.6);
  display:none; z-index:600;
}
.lang-dd.open { display:block; animation:popDown .2s ease; }
@keyframes popDown { from{opacity:0;transform:translateY(-8px)} to{opacity:1;transform:none} }
.lang-opt {
  display:flex; align-items:center; gap:11px;
  padding:11px 14px; border-radius:9px; cursor:pointer;
  font-size:13px; color:rgba(255,255,255,.65); transition:all .15s;
}
.lang-opt:hover { background:rgba(201,168,76,.1); color:var(--goldb); }
.lang-opt.on { color:var(--gold); background:rgba(201,168,76,.08); font-weight:600; }
.lang-opt .flag { font-size:18px; width:26px; text-align:center; }

/* CTA nav button */
.nav-cta {
  display:flex; align-items:center; gap:8px;
  background:linear-gradient(135deg,var(--goldb),var(--gold),var(--goldd));
  color:var(--ob); font-family:'Cinzel',serif; font-size:11px; font-weight:600;
  letter-spacing:.1em; padding:10px 22px; border-radius:10px;
  box-shadow:0 4px 20px rgba(201,168,76,.3); transition:all .25s;
}
.nav-cta:hover { transform:translateY(-2px); box-shadow:0 10px 32px rgba(201,168,76,.5); }

.nav-toggle {
  display:none; width:44px; height:44px; border-radius:10px;
  background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1);
  flex-direction:column; align-items:center; justify-content:center; gap:5px;
}
.nav-toggle span { width:18px; height:1.5px; background:white; border-radius:99px; display:block; transition:all .22s; }
.nav-toggle.act span:nth-child(1) { transform:translateY(6.5px) rotate(45deg); }
.nav-toggle.act span:nth-child(2) { opacity:0; }
.nav-toggle.act span:nth-child(3) { transform:translateY(-6.5px) rotate(-45deg); }

/* ═══════════════════════════════════════
   HERO — Cinematic Slideshow
═══════════════════════════════════════ */
.hero { position:relative; height:100vh; min-height:680px; overflow:hidden; }
.hero-slides { position:absolute; inset:0; }
.hslide {
  position:absolute; inset:0; opacity:0; transition:opacity 1.4s ease;
  background-size:cover; background-position:center;
}
.hslide.act { opacity:1; }
.hslide::after {
  content:''; position:absolute; inset:0;
  background:
    linear-gradient(105deg, rgba(7,8,15,.88) 0%, rgba(7,8,15,.5) 55%, rgba(7,8,15,.2) 100%),
    linear-gradient(to top, rgba(7,8,15,.7) 0%, transparent 50%);
}
/* Fallback placeholder gradients while images load */
.hslide:nth-child(1) { background-color:#1a1208; }
.hslide:nth-child(2) { background-color:#0d1020; }
.hslide:nth-child(3) { background-color:#140a1a; }

.hero-bg-img {
  position:absolute; inset:0; width:100%; height:100%; object-fit:cover;
  transition:transform 8s ease; transform:scale(1.06);
}
.hslide.act .hero-bg-img { transform:scale(1); }

/* Ken Burns overlay grid */
.hero-grid {
  position:absolute; inset:0; z-index:2; pointer-events:none;
  background-image:
    linear-gradient(rgba(201,168,76,.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(201,168,76,.03) 1px, transparent 1px);
  background-size:80px 80px;
}
.hero-content {
  position:absolute; inset:0; z-index:5;
  display:flex; flex-direction:column; justify-content:center;
  padding:0 10% 80px;
  max-width:860px;
}
.hero-eyebrow {
  display:flex; align-items:center; gap:16px; margin-bottom:30px;
  opacity:0; animation:slideIn .9s .3s forwards;
}
.hero-pulse { width:8px; height:8px; border-radius:50%; background:var(--goldb); position:relative; flex-shrink:0; }
.hero-pulse::after { content:''; position:absolute; inset:-5px; border-radius:50%; background:rgba(201,168,76,.25); animation:pulse 2.2s infinite; }
@keyframes pulse { 0%,100%{transform:scale(1);opacity:.6} 50%{transform:scale(2);opacity:0} }
.hero-eyebrow-txt { font-family:'Cinzel',serif; font-size:11px; letter-spacing:.22em; color:var(--gold); text-transform:uppercase; }
@keyframes slideIn { from{opacity:0;transform:translateX(-24px)} to{opacity:1;transform:none} }

.hero-title {
  font-family:'Libre Baskerville', serif; font-weight:700;
  font-size:clamp(50px,7.5vw,108px); line-height:.96; letter-spacing:-.03em;
  color:white; opacity:0; animation:riseUp 1s .5s forwards;
}
.hero-title .line2 { font-style:italic; color:var(--goldb); display:block; margin-left:.06em; text-shadow:0 0 80px rgba(201,168,76,.35); }
.hero-title .line3 { display:block; -webkit-text-stroke:1.5px rgba(255,255,255,.25); color:transparent; }
@keyframes riseUp { from{opacity:0;transform:translateY(40px)} to{opacity:1;transform:none} }

.hero-sub {
  font-size:clamp(14px,1.5vw,18px); color:rgba(255,255,255,.6); line-height:1.85;
  margin-top:22px; max-width:500px; font-weight:400;
  opacity:0; animation:fadeUp .9s .8s forwards;
}
@keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:none} }

.hero-tags { display:flex; gap:10px; flex-wrap:wrap; margin-top:28px; opacity:0; animation:fadeUp .9s 1s forwards; }
.hero-tag {
  display:inline-flex; align-items:center; gap:7px;
  background:rgba(201,168,76,.07); border:1px solid rgba(201,168,76,.18);
  color:var(--ivory); font-size:12px; padding:7px 15px; border-radius:999px;
  letter-spacing:.04em;
}
.hero-tag span { color:var(--goldb); font-size:14px; }

.hero-btns { display:flex; gap:14px; flex-wrap:wrap; margin-top:38px; opacity:0; animation:fadeUp .9s 1.1s forwards; }
.btn-main {
  display:inline-flex; align-items:center; gap:10px;
  background:linear-gradient(135deg,var(--goldb) 0%,var(--gold) 50%,#8A6820 100%);
  color:var(--ob); font-family:'Cinzel',serif; font-size:12px; font-weight:600;
  letter-spacing:.1em; padding:17px 36px; border-radius:12px;
  box-shadow:0 14px 44px rgba(201,168,76,.38), inset 0 1px 0 rgba(255,255,255,.2);
  transition:all .3s; position:relative; overflow:hidden;
}
.btn-main::after {
  content:''; position:absolute; top:-50%; left:-60%; width:40%; height:200%;
  background:rgba(255,255,255,.15); transform:skewX(-20deg);
  animation:shimmer 3s 2s infinite;
}
@keyframes shimmer { 0%{left:-60%} 100%{left:140%} }
.btn-main:hover { transform:translateY(-3px); box-shadow:0 22px 56px rgba(201,168,76,.55); }
.btn-ghost {
  display:inline-flex; align-items:center; gap:10px;
  color:rgba(255,255,255,.8); font-family:'Cinzel',serif; font-size:12px; letter-spacing:.1em;
  padding:17px 36px; border-radius:12px; border:1.5px solid rgba(255,255,255,.2);
  backdrop-filter:blur(8px); background:rgba(255,255,255,.04); transition:all .25s;
}
.btn-ghost:hover { border-color:var(--gold); color:var(--goldb); background:rgba(201,168,76,.07); }

/* Hero side stats */
.hero-stats {
  position:absolute; right:7%; bottom:80px; z-index:5;
  display:flex; gap:12px;
  opacity:0; animation:fadeUp .9s 1.3s forwards;
}
.hstat {
  background:rgba(7,8,15,.6); backdrop-filter:blur(20px);
  border:1px solid rgba(201,168,76,.2); border-radius:16px;
  padding:18px 22px; text-align:center; min-width:110px;
}
.hstat-n { font-family:'Libre Baskerville',serif; font-size:30px; font-weight:700; color:var(--goldb); line-height:1; }
.hstat-l { font-family:'Cinzel',serif; font-size:9px; color:rgba(255,255,255,.4); margin-top:6px; letter-spacing:.1em; text-transform:uppercase; }

/* Slide controls */
.hero-ctrl {
  position:absolute; bottom:34px; left:10%; z-index:5;
  display:flex; align-items:center; gap:18px;
}
.hero-dots { display:flex; gap:7px; }
.hdot { width:7px; height:7px; border-radius:50%; background:rgba(255,255,255,.25); cursor:pointer; transition:all .3s; }
.hdot.act { background:var(--goldb); width:28px; border-radius:4px; }
.hero-arr {
  width:38px; height:38px; border-radius:50%; border:1px solid rgba(255,255,255,.18);
  background:rgba(255,255,255,.06); color:white; font-size:16px;
  display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all .2s;
}
.hero-arr:hover { background:rgba(201,168,76,.2); border-color:var(--gold); color:var(--goldb); }

/* Scroll indicator */
.scroll-hint {
  position:absolute; bottom:36px; left:50%; transform:translateX(-50%);
  z-index:5; display:flex; flex-direction:column; align-items:center; gap:9px;
  color:rgba(255,255,255,.25); font-family:'Cinzel',serif; font-size:9px; letter-spacing:.18em;
  animation:bob 2.5s infinite;
}
@keyframes bob { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(7px)} }
.scroll-mouse { width:20px; height:32px; border:1.5px solid rgba(255,255,255,.18); border-radius:10px; display:flex; justify-content:center; padding-top:5px; }
.scroll-dot { width:3px; height:7px; background:var(--gold); border-radius:2px; animation:sdot 2s infinite; }
@keyframes sdot { 0%,100%{opacity:1;transform:none} 100%{opacity:0;transform:translateY(10px)} }

/* ═══════════════════════════════════════
   MARQUEE
═══════════════════════════════════════ */
.marquee-strip { background:var(--ob3); border-top:1px solid var(--border); border-bottom:1px solid var(--border); overflow:hidden; padding:16px 0; }
.mq-track { display:flex; gap:0; animation:mq 35s linear infinite; width:max-content; }
.mq-track:hover { animation-play-state:paused; }
@keyframes mq { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
.mq-item {
  display:flex; align-items:center; gap:10px;
  padding:0 32px; border-right:1px solid rgba(201,168,76,.12);
  white-space:nowrap;
}
.mq-item .icon { font-size:16px; }
.mq-item .txt { font-family:'Cinzel',serif; font-size:11px; letter-spacing:.15em; color:rgba(255,255,255,.45); text-transform:uppercase; }

/* ═══════════════════════════════════════
   EVENTS SECTION — Kinetic Cards
═══════════════════════════════════════ */
.events { padding:120px 0; background:var(--ob); }
.events-intro { display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:end; margin-bottom:64px; }
.events-cards { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
.ev-card {
  position:relative; border-radius:24px; overflow:hidden;
  min-height:540px; cursor:pointer; group:true;
}
.ev-card-img {
  position:absolute; inset:0;
}
.ev-card-img img {
  width:100%; height:100%; object-fit:cover;
  transition:transform 1s cubic-bezier(.25,.46,.45,.94);
  display:block;
}
.ev-card:hover .ev-card-img img { transform:scale(1.07); }
/* Fallback colors if images missing */
.ev-card:nth-child(1) .ev-card-img { background:#1a1208; }
.ev-card:nth-child(2) .ev-card-img { background:#0d1020; }

.ev-card-shade {
  position:absolute; inset:0;
  background:linear-gradient(to top, rgba(7,8,15,.98) 0%, rgba(7,8,15,.55) 45%, rgba(7,8,15,.12) 100%);
}
.ev-card-corner {
  position:absolute; top:26px; right:26px;
  width:46px; height:46px; border-radius:50%;
  border:1.5px solid rgba(201,168,76,.3); background:rgba(201,168,76,.07);
  display:flex; align-items:center; justify-content:center;
  font-size:20px; color:var(--goldb); transition:all .35s;
}
.ev-card:hover .ev-card-corner { background:var(--gold); transform:rotate(45deg) scale(1.1); }
.ev-card-body { position:absolute; bottom:0; left:0; right:0; padding:38px; }
.ev-pill {
  display:inline-flex; align-items:center; gap:7px;
  background:rgba(201,168,76,.1); border:1px solid rgba(201,168,76,.25);
  color:var(--goldb); font-family:'Cinzel',serif; font-size:10px; letter-spacing:.12em;
  padding:5px 14px; border-radius:999px; margin-bottom:16px; text-transform:uppercase;
}
.ev-card h3 { font-family:'Libre Baskerville',serif; font-size:30px; font-weight:700; color:white; line-height:1.18; margin-bottom:12px; }
.ev-card p { font-size:13.5px; color:rgba(255,255,255,.55); line-height:1.75; margin-bottom:22px; }
.ev-specs { display:flex; gap:16px; flex-wrap:wrap; }
.ev-spec { display:flex; align-items:center; gap:6px; font-size:12px; color:rgba(255,255,255,.45); }
.ev-spec .dot { width:5px; height:5px; border-radius:50%; background:var(--gold); flex-shrink:0; }

/* ═══════════════════════════════════════
   GALLERY — Overlapping Reveal
═══════════════════════════════════════ */
.gallery { padding:120px 0; background:var(--ob2); }
.gallery-hdr { text-align:center; margin-bottom:64px; }
.gallery-hdr .sec-p { margin:0 auto; }
.gal-grid {
  display:grid;
  grid-template-columns:1.6fr 1fr 1fr;
  grid-template-rows:300px 300px;
  gap:10px;
}
.gal-cell {
  position:relative; overflow:hidden; border-radius:16px; cursor:pointer;
  background:var(--ob3);
}
.gal-cell.tall { grid-row:span 2; }
.gal-cell img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .8s cubic-bezier(.25,.46,.45,.94); }
.gal-cell:hover img { transform:scale(1.06); }
.gal-layer {
  position:absolute; inset:0;
  background:linear-gradient(to top, rgba(7,8,15,.75) 0%, transparent 55%);
  opacity:0; transition:opacity .4s;
  display:flex; align-items:flex-end; padding:22px;
}
.gal-cell:hover .gal-layer { opacity:1; }
.gal-lbl { font-family:'Cinzel',serif; font-size:12px; letter-spacing:.12em; color:var(--goldb); text-transform:uppercase; }
/* Gold border on hover */
.gal-cell::before {
  content:''; position:absolute; inset:0; border-radius:16px;
  border:1.5px solid var(--gold); opacity:0; transition:opacity .4s; z-index:2; pointer-events:none;
}
.gal-cell:hover::before { opacity:.7; }

/* ═══════════════════════════════════════
   STATS BAR
═══════════════════════════════════════ */
.stats-bar {
  padding:80px 0;
  background:linear-gradient(170deg, var(--ob3) 0%, var(--ob) 100%);
  border-top:1px solid var(--border); border-bottom:1px solid var(--border);
  position:relative; overflow:hidden;
}
.stats-bar::before {
  content:''; position:absolute; top:-40%; left:30%; width:500px; height:500px;
  background:radial-gradient(circle, rgba(201,168,76,.06) 0%, transparent 70%);
  pointer-events:none;
}
.stats-row { display:grid; grid-template-columns:repeat(4,1fr); }
.st-item { text-align:center; padding:20px 30px; border-right:1px solid rgba(201,168,76,.1); }
.st-item:last-child { border-right:none; }
.st-num {
  font-family:'Libre Baskerville',serif; font-size:60px; font-weight:700; line-height:1;
  background:linear-gradient(135deg,var(--goldb),var(--gold));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
}
.st-lbl { font-family:'Cinzel',serif; font-size:10px; letter-spacing:.15em; color:rgba(255,255,255,.35); margin-top:8px; text-transform:uppercase; }

/* ═══════════════════════════════════════
   PRICING — clean 2-column (no BPJS)
═══════════════════════════════════════ */
.pricing { padding:120px 0; background:var(--ob); }
.pricing-hdr { text-align:center; margin-bottom:70px; }
