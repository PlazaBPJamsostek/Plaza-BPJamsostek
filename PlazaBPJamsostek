  addMsg(q,'user'); aiIn.value=''; sendAI(q);
});
aiIn.addEventListener('keydown', function(e){ if(e.key==='Enter'){ var q=aiIn.value.trim(); if(!q||aiBusy) return; addMsg(q,'user'); aiIn.value=''; sendAI(q); } });
aiSugg.querySelectorAll('.ai-sugg').forEach(function(b){
  b.addEventListener('click', function(){ addMsg(b.dataset.q,'user'); sendAI(b.dataset.q); });
});

/* ══════════════════════════════════
   LANGUAGE SELECTOR + AI TRANSLATE
══════════════════════════════════ */
var langBtn = document.getElementById('langBtn');
var langDD  = document.getElementById('langDD');
var langLbl = document.getElementById('langLbl');
var curLang = 'id';
var origTexts = {};

langBtn.addEventListener('click', function(e){ e.stopPropagation(); langDD.classList.toggle('open'); });
document.addEventListener('click', function(){ langDD.classList.remove('open'); });

// Collect all translatable text on page load
function collectOrig(){
  document.querySelectorAll('[data-k]').forEach(function(el){
    var k = el.getAttribute('data-k');
    if(!origTexts[k]) origTexts[k] = el.textContent.trim();
  });
}
collectOrig();

var langFullName = {
  id:'Bahasa Indonesia', en:'English', ar:'Arabic', zh:'Simplified Chinese',
  ja:'Japanese', ko:'Korean', fr:'French', de:'German', es:'Spanish', ru:'Russian'
};
var langShort = { id:'ID',en:'EN',ar:'AR',zh:'ZH',ja:'JP',ko:'KR',fr:'FR',de:'DE',es:'ES',ru:'RU' };

function resetID(){
  document.querySelectorAll('[data-k]').forEach(function(el){
    var k = el.getAttribute('data-k');
    if(origTexts[k]) el.textContent = origTexts[k];
  });
  curLang='id'; langLbl.textContent='ID';
  document.documentElement.lang='id'; document.documentElement.dir='ltr';
}

async function translatePage(lang){
  if(lang===curLang) return;
  var overlay=document.getElementById('tlOverlay');
  document.getElementById('tlTxt').textContent = 'Menerjemahkan halaman...';
  document.getElementById('tlLang').textContent = '→ '+langFullName[lang];
  overlay.classList.add('show');

  // Gather unique texts (use original values)
  var keys = Object.keys(origTexts);
  var texts = keys.map(function(k){ return origTexts[k]; });

  // Deduplicate
  var unique = [...new Set(texts)];

  var prompt = 'Translate these UI text strings into ' + langFullName[lang] + '.\n'
    + 'Return ONLY a valid JSON object: { "original text": "translation" }.\n'
    + 'Rules:\n'
    + '- Keep emojis exactly as-is\n'
    + '- Do NOT translate: Plaza BPJamsostek, Jl. HR Rasuna Said, PT Sinergi Investasi Properti, WhatsApp, Instagram, YouTube, Grade A, Green Building, Kuningan\n'
    + '- Numbers and prices keep format (Rp, Juta)\n'
    + '- No markdown, no explanation — pure JSON only\n\n'
    + 'Texts:\n' + JSON.stringify(unique);

  try{
    var res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:4000,messages:[{role:'user',content:prompt}]})
    });
    var data = await res.json();
    var raw = (data.content && data.content[0] && data.content[0].text) ? data.content[0].text : '{}';
    var clean = raw.replace(/```json|```/g,'').trim();
    var si = clean.indexOf('{'), ei = clean.lastIndexOf('}');
    if(si!==-1 && ei!==-1) clean = clean.slice(si,ei+1);
    var tr = JSON.parse(clean);

    document.querySelectorAll('[data-k]').forEach(function(el){
      var k = el.getAttribute('data-k');
      var orig = origTexts[k];
      if(orig && tr[orig]) el.textContent = tr[orig];
    });

    curLang = lang;
    langLbl.textContent = langShort[lang] || lang.toUpperCase();
    document.documentElement.lang = lang;
    document.documentElement.dir = (lang==='ar') ? 'rtl' : 'ltr';
  } catch(err){
    document.getElementById('tlTxt').textContent = 'Gagal menerjemahkan.';
    setTimeout(function(){ overlay.classList.remove('show'); }, 1400);
    return;
  }
  overlay.classList.remove('show');
}

document.querySelectorAll('.lang-opt').forEach(function(opt){
  opt.addEventListener('click', function(e){
    e.stopPropagation();
    var lang = this.getAttribute('data-l');
    document.querySelectorAll('.lang-opt').forEach(function(o){ o.classList.remove('on'); });
    this.classList.add('on');
    langDD.classList.remove('open');
    if(lang==='id') resetID(); else translatePage(lang);
  });
});
</script>
