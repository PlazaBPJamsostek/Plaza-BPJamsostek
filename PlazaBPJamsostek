/* ══════════════════════════════════
   HERO SLIDESHOW
══════════════════════════════════ */
var hCur = 0, hTotal = 3, hAuto;
function hGo(n){
  document.getElementById('hs'+hCur).classList.remove('act');
  document.querySelectorAll('.hdot')[hCur].classList.remove('act');
  hCur = (n + hTotal) % hTotal;
  document.getElementById('hs'+hCur).classList.add('act');
  document.querySelectorAll('.hdot')[hCur].classList.add('act');
}
document.getElementById('hPrev').onclick = function(){ clearInterval(hAuto); hGo(hCur-1); hAuto=setInterval(function(){hGo(hCur+1);},6000); };
document.getElementById('hNext').onclick = function(){ clearInterval(hAuto); hGo(hCur+1); hAuto=setInterval(function(){hGo(hCur+1);},6000); };
document.querySelectorAll('.hdot').forEach(function(d){ d.onclick = function(){ clearInterval(hAuto); hGo(+d.dataset.i); hAuto=setInterval(function(){hGo(hCur+1);},6000); }; });
hAuto = setInterval(function(){ hGo(hCur+1); }, 6000);

